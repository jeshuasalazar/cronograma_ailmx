# Variables de entorno para el frontend (Vite).
# Obténlas en supabase.com → tu proyecto → Settings → API:
#   - VITE_SUPABASE_URL      = "Project URL"
#   - VITE_SUPABASE_ANON_KEY = "anon public" key (NUNCA la "service_role")
#
# Copia este archivo a ".env" (o ".env.local") y rellena los valores.
# Configura las mismas variables en Railway → tu servicio → Variables.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
